generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(CUSTOMER)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  sortOrder   Int      @default(0)
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  price       Float
  salePrice   Float?
  images      String        @default("[]")
  featured     Boolean       @default(false)
  monthlySales Int           @default(0)
  salesResetAt DateTime      @default(now())
  status       ProductStatus @default(ACTIVE)
  categoryId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  category   Category      @relation(fields: [categoryId], references: [id])
  sizes      ProductSize[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([slug])
}

model ProductSize {
  id        String @id @default(cuid())
  productId String
  label     String
  stock     Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, label])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  status        OrderStatus @default(PENDING)
  total         Float
  customerName  String
  customerEmail String
  customerPhone String
  address       String
  city          String
  county        String
  postalCode    String
  notes         String?
  userId        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int
  size      String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}
